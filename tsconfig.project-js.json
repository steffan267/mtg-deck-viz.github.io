{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "strict": false,
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["node"]
  },
  "include": [
    "src/**/*.js",
    "src/domain/**/*.ts",
    "bin/**/*.js",
    "lib/**/*.js",
    "scripts/**/*.js",
    "analysis/**/*.js",
    "deploy/**/*.js"
  ],
  "exclude": [
    "assets/**",
    "docs/**",
    "dist/**",
    "node_modules/**"
  ]
}
